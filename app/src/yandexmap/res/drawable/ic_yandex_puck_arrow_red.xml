<?xml version="1.0" encoding="utf-8"?>
<!--
  User-location puck for the yandexmap flavor — red forward-pointing arrow.
  Same geometry as ic_yandex_puck_arrow_blue (centered at (32,32), arrow up
  at zero rotation) so swapping at runtime via PlacemarkMapObject.setIcon
  lands in the same coordinate without any anchor recalculation.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="64"
    android:viewportHeight="64">
    <path
        android:fillColor="#33E53935"
        android:pathData="M32,32 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0z" />
    <path
        android:fillColor="#FFE53935"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:pathData="M32,8 L50,48 L32,40 L14,48 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M32,32 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0z" />
</vector>
