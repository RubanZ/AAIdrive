<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Yandex MapKit Full requires Android 8.0+ (API 26). Other map flavors stay on 23. -->
    <uses-sdk android:minSdkVersion="26" />

    <application>
        <!-- ContentProvider-as-init shim: instantiated on the main thread during
             Application.attach(), guarantees MapKitFactory.initialize runs before
             any Service/Activity touches MapKit, and on the main looper that
             Yandex's native code requires. See YandexMapKitInitProvider. -->
        <provider
            android:name=".maps.YandexMapKitInitProvider"
            android:authorities="${applicationId}.yandexmapkit-init"
            android:exported="false"
            android:initOrder="100" />

        <service android:name=".carapp.maps.MapAppService" android:exported="false">
            <intent-filter>
                <action android:name="me.hufman.androidautoidrive.carconnection.service" />
            </intent-filter>
        </service>

        <service android:name=".MapTestingService"
            android:label="@string/lbl_map_testing"
            android:exported="false"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="me.hufman.androidautoidrive.MapTestingService.start" />
                <action android:name="me.hufman.androidautoidrive.MapTestingService.stop" />
            </intent-filter>
        </service>
    </application>
</manifest>
