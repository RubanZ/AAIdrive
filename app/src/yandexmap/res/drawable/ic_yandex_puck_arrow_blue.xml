<?xml version="1.0" encoding="utf-8"?>
<!--
  User-location puck for the yandexmap flavor — blue forward-pointing arrow.
  64x64 viewport with the geometric center at (32,32) so PlacemarkMapObject
  with anchor (0.5, 0.5) lands the GPS coordinate exactly under the arrow's
  pivot. The arrow points "up" (north) at zero rotation; YandexMapsProjection
  rotates it via setDirection(bearing) on every CDS tick.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="64"
    android:viewportHeight="64">
    <!-- Outer halo (lighter blue, semi-transparent) for visibility on dark tiles -->
    <path
        android:fillColor="#332E7AFF"
        android:pathData="M32,32 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0z" />
    <!-- Solid arrow body, deep blue -->
    <path
        android:fillColor="#FF2E7AFF"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:pathData="M32,8 L50,48 L32,40 L14,48 Z" />
    <!-- Center dot, white, for "I am here" emphasis -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M32,32 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0z" />
</vector>
